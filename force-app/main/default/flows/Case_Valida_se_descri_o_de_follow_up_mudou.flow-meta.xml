        <defaultConnectorLabel>Não</defaultConnectorLabel>
        <rules>
            <name>SimDescriptionChanged</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>FormulaIsChangedFollowUpComentary</leftValueReference>
