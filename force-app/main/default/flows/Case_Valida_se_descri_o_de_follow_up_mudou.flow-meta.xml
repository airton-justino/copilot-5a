    <description>Valida se descrição de follow up mudou.</description>
    <environments>Default</environments>
    <formulas>
        <name>FormulaIsChangedFollowUpComentary</name>
        <dataType>Boolean</dataType>
        <expression>AND(
ISCHANGED({!$Record.followUpDescription__c}),
NOT(ISBLANK({!$Record.followUpDescription__c}))
)</expression>
    </formulas>
