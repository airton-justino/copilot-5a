            </value>
        </inputAssignments>
        <inputAssignments>
            <name>PriorTask</name>
            <value>
                <elementReference>$Record__Prior</elementReference>
            </value>
        </inputAssignments>
    </subflows>
    <subflows>
        <name>LockboxLogic</name>
        <label>Lógica de Lockbox</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <flowName>Task_FlowMaestroTaskKeyLogisticsForRentOffboardingLockbox</flowName>
        <inputAssignments>
            <name>NewTask</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>PriorTask</name>
            <value>
                <elementReference>$Record__Prior</elementReference>
            </value>
        </inputAssignments>
    </subflows>
    <subflows>
