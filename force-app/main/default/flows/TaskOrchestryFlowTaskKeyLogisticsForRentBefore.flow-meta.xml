    </customErrors>
    <decisions>
        <name>Check_operation_context</name>
        <label>Check operation context</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>delete context</defaultConnectorLabel>
        <rules>
            <name>insert_context</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.Id</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>VerifyTaskRecordType</targetReference>
            </connector>
            <label>insert context</label>
        </rules>
        <rules>
            <name>update_context</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.Id</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Id</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Resolved_task</targetReference>
            </connector>
            <label>update context</label>
        </rules>
    </decisions>
    <decisions>
        <name>FilesFound</name>
        <label>Files Found?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>DontExistAttach</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Resultado padrão</defaultConnectorLabel>
        <rules>
            <name>Found_Files</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>GetContentDocumentLink</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <label>Found Files</label>
        </rules>
    </decisions>
    <decisions>
        <name>Resolved_task</name>
        <label>Check task status</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Resolved</name>
            <conditionLogic>1 AND 2 AND (3 OR 4)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Completed</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Answer__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>true</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Type</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>KL_FR_OF_CONTACT_PP_REQUEST_LOCKSMITH</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Type</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>KL_FR_ON_CONTACT_IQ_ALLOW_CALL_LOCKSMITH</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>GetContentDocumentLink</targetReference>
            </connector>
            <label>Resolved</label>
        </rules>
    </decisions>
    <decisions>
        <description>Verify task record type</description>
        <name>VerifyTaskRecordType</name>
        <label>Verify task record type</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Else</defaultConnectorLabel>
        <rules>
            <name>IsKeyLogisticsForRentRecordType</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>KeyLogisticsForRentRecordType</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>GetRelatedTaskManagement</targetReference>
            </connector>
            <label>Is key logistics for rent record type</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>NewOwnerId</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!$Record.Owner:User.Id}), {!$Record.OwnerId}, {!$Record.Owner:User.Id})</expression>
    </formulas>
    <formulas>
        <name>Subject</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!GetRelatedTaskManagement.Subject__c}), {!$Record.Subject}, {!GetRelatedTaskManagement.Subject__c})</expression>
    </formulas>
    <interviewLabel>[Taks] Flow Maestro Tasks Key Logistics For Rent Before {!$Flow.CurrentDateTime}</interviewLabel>
