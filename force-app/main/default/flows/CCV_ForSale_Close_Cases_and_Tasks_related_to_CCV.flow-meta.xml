    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Case_related_CCV</targetReference>
        </connector>
        <filterFormula>AND(
    OR(
        ISPICKVAL({!$Record.CCVStatus__c}, &quot;Concluído&quot;),
        ISPICKVAL({!$Record.CCVStatus__c}, &quot;Cancelado&quot;)
    ),
    OR(
        ISPICKVAL({!$Record.PaymentMethod__c}, &quot;Financiado&quot;),
        ISPICKVAL({!$Record.PaymentMethod__c}, &quot;Financiado com FGTS&quot;)
    ),
    NOT(ISBLANK({!$Record.Opportunity__c})),
    {!$Record.RecordType.DeveloperName} = &quot;Financed&quot;
)</filterFormula>
        <object>PurchaseSaleContract__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
