    <decisions>
        <name>Does_Inbound_Event_Exists</name>
        <label>Does Inbound Event Exists And Is Integration User</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>X15_or_30_days</name>
            <conditionLogic>1 AND (2 OR 3) AND (NOT(4) OR NOT(5))</conditionLogic>
            <conditions>
                <leftValueReference>Get_Inbound_Event</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>nowMinusInboundCreatedDateWithTest</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>15.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>nowMinusInboundCreatedDateWithTest</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>30.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_User.Name</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Integração</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_User.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Bruno Donizeti</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Task</targetReference>
            </connector>
            <label>15 or 30 days</label>
        </rules>
    </decisions>
    <decisions>
        <name>Does_Task_Exist</name>
        <label>Does Task Exist?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Get_Task_Record_Type</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Task</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Withdrawl_from_purchase_process</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>Withdrawl_from_purchase_process</name>
        <label>Withdrawl from purchase process</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>No</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>nowMinusInboundCreatedDateWithTest</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>30.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Task.FS_BuyerWithdrawnFromPurchaseProcess__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Não</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Event_for_Inactivity</targetReference>
            </connector>
            <label>No</label>
        </rules>
        <rules>
            <name>X15_Days</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Task.IsClosed</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>nowMinusInboundCreatedDateWithTest</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>15.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <isGoTo>true</isGoTo>
                <targetReference>Get_Task_Record_Type</targetReference>
            </connector>
            <label>15 Days</label>
        </rules>
    </decisions>
    <description>Subflow com as regras de negócio para o desencarteiramento</description>
