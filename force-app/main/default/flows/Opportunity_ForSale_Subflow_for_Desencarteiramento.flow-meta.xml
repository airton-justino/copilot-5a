    <formulas>
        <name>nowMinusInboundCreatedDate</name>
        <dataType>Number</dataType>
        <expression>NOW() - {!Get_Inbound_Event.CreatedDate}</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>nowMinusInboundCreatedDateWithTest</name>
        <dataType>Number</dataType>
        <expression>IF(NOT(ISBLANK({!var_SimulatedDateTime})), 
   NOW() - {!var_SimulatedDateTime}, 
   NOW() - {!Get_Inbound_Event.CreatedDate}
)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>olderName</name>
        <dataType>String</dataType>
        <expression>{!Opportunity.Account.FirstName} &amp; &quot; &quot; &amp; {!Opportunity.Account.LastName}</expression>
    </formulas>
