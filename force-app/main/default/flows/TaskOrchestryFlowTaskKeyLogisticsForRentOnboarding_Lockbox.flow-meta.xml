    <recordUpdates>
        <name>Update_CaseIQSuccess</name>
        <label>Update Case IQ Success</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Case_Task_Finalizar_Caso_e_Cancelar_Tarefas</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>NewTask.WhatId</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>ContactReplyIQ__c</field>
            <value>
                <stringValue>success</stringValue>
            </value>
        </inputAssignments>
        <object>Case</object>
    </recordUpdates>
    <recordUpdates>
        <name>Update_related_case_IQ_Pending</name>
        <label>Update related case (IQ Pending)</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
