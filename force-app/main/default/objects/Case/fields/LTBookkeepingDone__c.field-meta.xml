<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>LTBookkeepingDone__c</fullName>
    <externalId>false</externalId>
    <formula>IF(
    OR(
        ISNULL(BookkeepingDoneDate__c), 
        ISNULL(PurchaseSaleContract__r.CCVSignedAt__c)
    ), 
    0, 
    ABS(
        BookkeepingDoneDate__c  - DATEVALUE(PurchaseSaleContract__r.CCVSignedAt__c)
    )
)</formula>
    <label>LT de escritura</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
